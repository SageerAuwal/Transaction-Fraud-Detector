# Gojo Sentinel Configuration Example
# ─────────────────────────────────────────────────────────────────
# Copy this file to 'config.env' and update the values.

# API Authentication
# Change this key before deploying! Keep it secret.
API_KEY=your-secret-key-here

# Rate Limiting (requests per minute per IP)
RATE_LIMIT=60

# Database path for prediction logs
DB_PATH=data/predictions.db

# Model paths
MODEL_PATH=models/xgb_model.json
PREPROCESSOR_PATH=models/preprocessor.pkl
THRESHOLD_PATH=models/threshold.json

# ─── NIBSS Integration (Optional) ────────────────────────────────
# Obtain from https://www.nibss-plc.com.ng/
NIBSS_BASE_URL=https://api.nibss-plc.com.ng/v1
NIBSS_API_KEY=
NIBSS_CERT_PATH=

# ─── Environment ─────────────────────────────────────────────────
ENV=development
